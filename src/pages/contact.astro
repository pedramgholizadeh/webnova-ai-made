---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="Contact" description="Get in touch with WebNova. Let's discuss your next creative project in Berlin or across Europe.">
  <div class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <div class="max-w-2xl mb-12">
      <h1 class="text-6xl font-semibold tracking-[-1.8px] mb-4">{t('contact.title')}</h1>
      <p class="text-2xl text-zinc-400">{t('contact.subtitle')}</p>
    </div>

    <div class="grid lg:grid-cols-5 gap-x-16 gap-y-12">
      <!-- Form -->
      <div class="lg:col-span-3">
        <form 
          id="contact-form"
          action="https://formspree.io/f/your-form-id" 
          method="POST"
          class="space-y-6"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm text-zinc-400 mb-2" for="name">{t('contact.form.name')}</label>
              <input type="text" id="name" name="name" required class="w-full" placeholder="Jane Doe" />
            </div>
            <div>
              <label class="block text-sm text-zinc-400 mb-2" for="email">{t('contact.form.email')}</label>
              <input type="email" id="email" name="email" required class="w-full" placeholder="you@company.com" />
            </div>
          </div>

          <div>
            <label class="block text-sm text-zinc-400 mb-2" for="company">{t('contact.form.company')}</label>
            <input type="text" id="company" name="company" class="w-full" placeholder="Your Company" />
          </div>

          <div>
            <label class="block text-sm text-zinc-400 mb-2" for="message">{t('contact.form.message')}</label>
            <textarea 
              id="message" 
              name="message" 
              rows={7} 
              required 
              class="w-full resize-y min-h-[160px]"
              placeholder="Tell us about your project, timeline, and goals..."
            ></textarea>
          </div>

          <div class="pt-2">
            <button 
              type="submit"
              class="btn btn-primary w-full sm:w-auto px-10 py-3.5 text-base"
            >
              {t('contact.form.submit')}
            </button>
          </div>
          
          <p id="form-success" class="hidden text-sm text-[#22c55e] pt-2">{t('contact.form.success')}</p>
        </form>
      </div>

      <!-- Office Info -->
      <div class="lg:col-span-2 space-y-10">
        <div>
          <div class="uppercase tracking-[1.5px] text-xs text-zinc-500 mb-4">{t('contact.office.title')}</div>
          <div class="space-y-1.5 text-lg">
            <div>{t('contact.office.address')}</div>
            <a href="mailto:hello@webnova.studio" class="block text-[#3b82f6] hover:underline">{t('contact.office.email')}</a>
            <a href="tel:+49301234567" class="block text-zinc-400 hover:text-white">{t('contact.office.phone')}</a>
          </div>
        </div>

        <div>
          <div class="uppercase tracking-[1.5px] text-xs text-zinc-500 mb-4">FOLLOW</div>
          <div class="flex gap-6 text-sm">
            <a href="#" class="hover:text-white">LinkedIn</a>
            <a href="#" class="hover:text-white">Instagram</a>
            <a href="#" class="hover:text-white">Behance</a>
          </div>
        </div>

        <div class="pt-4 border-t border-zinc-800 text-sm text-zinc-400">
          We typically respond within two business days.<br />
          For urgent inquiries: <span class="text-white">hello@webnova.studio</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Simple form handling for demo (replace with real Formspree / Netlify)
    const form = document.getElementById('contact-form');
    const successMsg = document.getElementById('form-success');

    if (form) {
      form.addEventListener('submit', (e) => {
        // For now, prevent real submit and show success (demo)
        // Remove this in production when using real endpoint
        e.preventDefault();
        
        form.style.display = 'none';
        if (successMsg) successMsg.classList.remove('hidden');
        
        // In real use, remove the preventDefault and let the form post
        // Or use fetch to submit to Formspree.
      });
    }
  </script>
</Layout>
