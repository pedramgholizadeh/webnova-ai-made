---
import Layout from '../layouts/Layout.astro';

const team = [
  { name: "Anna Bergmann", role: "Creative Director & Founder", bio: "Formerly at Meta. Obsessed with clarity, craft and emotional impact in digital experiences.", image: "https://picsum.photos/id/1005/400/400" },
  { name: "Maximilian Voss", role: "Head of Strategy", bio: "10+ years helping European brands find their voice. Previously at Wolff Olins.", image: "https://picsum.photos/id/1011/400/400" },
  { name: "Sofia Laurent", role: "Design Director", bio: "Award-winning designer passionate about systems thinking and digital craftsmanship.", image: "https://picsum.photos/id/1009/400/400" },
  { name: "Julian Keller", role: "Technical Director", bio: "Bridges design and engineering. Led digital product teams at a major European tech company.", image: "https://picsum.photos/id/201/400/400" },
  { name: "Lara Schmidt", role: "AI & Automation Lead", bio: "Specialist in AI implementation and business process automation for creative agencies.", image: "https://picsum.photos/id/29/400/400" },
  { name: "David Moreau", role: "Client Director", bio: "Ensures every project exceeds expectations. Background in management consulting.", image: "https://picsum.photos/id/160/400/400" },
];
---

<Layout title="Our Team | WebNova">
  <div class="max-w-6xl mx-auto px-6 pt-16 pb-24">
    <div class="max-w-2xl mb-12">
      <h1 class="text-6xl font-semibold tracking-[-2px] mb-4">Our Team</h1>
      <p class="text-2xl text-zinc-400">A small team of specialists obsessed with quality and results.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {team.map(member => (
        <div class="card p-8 rounded-3xl">
          <img src={member.image} alt={member.name} class="w-24 h-24 rounded-full object-cover mb-6" />
          <h3 class="text-2xl font-semibold">{member.name}</h3>
          <p class="text-[#3b82f6] mb-4">{member.role}</p>
          <p class="text-zinc-400">{member.bio}</p>
        </div>
      ))}
    </div>
  </div>
</Layout>
