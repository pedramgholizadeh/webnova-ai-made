---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/translations';
import { getAllServices } from '../data/ai-services';

const lang = getLangFromUrl(Astro.url) as 'en' | 'de';
const t = useTranslations(lang);
const services = getAllServices(lang).slice(0, 6);
---

<Layout title="WebNova | Premium Creative AI Agency" description="Premium creative agency based in Berlin. AI-powered design, websites, apps, and automation for ambitious brands across Europe.">
  <!-- Hero -->
  <section class="pt-24 pb-20 border-b border-zinc-800">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <div class="inline-block px-4 py-1 rounded-full border border-zinc-800 text-xs tracking-[2px] mb-6 text-[#3b82f6]">BERLIN • EUROPE</div>
      
      <h1 class="text-7xl md:text-[72px] font-semibold tracking-[-3.5px] leading-[0.9] mb-6">
        {lang === 'de' ? 'Kreativität trifft KI.' : 'Creativity meets AI.'}
      </h1>
      <p class="max-w-2xl mx-auto text-2xl text-zinc-400 mb-10">
        {lang === 'de' 
          ? 'Eine Premium Creative Agency aus Berlin. Wir kombinieren menschliche Kreativität mit KI für außergewöhnliche digitale Erlebnisse.' 
          : 'A premium creative agency from Berlin. We combine human creativity with AI to craft exceptional digital experiences.'}
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('/services', lang)} class="btn btn-primary px-9 py-4 text-base">Explore Services</a>
        <a href={getLocalizedPath('/contact', lang)} class="btn btn-secondary px-9 py-4 text-base">Book a Call</a>
      </div>
    </div>
  </section>

  <!-- Services Teaser -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <div class="text-[#3b82f6] text-sm tracking-[2px] mb-2">WHAT WE OFFER</div>
        <h2 class="text-4xl font-semibold tracking-tight">AI-Powered Services</h2>
      </div>
      <a href={getLocalizedPath('/services', lang)} class="hidden md:block text-sm text-[#3b82f6]">View all services →</a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map(service => (
        <a href={getLocalizedPath(`/services/${service.slug}`, lang)} class="group border border-zinc-800 p-8 rounded-3xl hover:border-[#3b82f6] transition-all">
          <div class="text-3xl mb-6">{service.icon}</div>
          <h3 class="font-semibold text-xl mb-3 group-hover:text-[#3b82f6]">{service.title}</h3>
          <p class="text-zinc-400 text-[15px] leading-relaxed line-clamp-3">{service.heroSubtitle}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Why WebNova -->
  <section class="bg-[#111113] py-20 border-y border-zinc-800">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <div class="text-[#3b82f6] text-sm tracking-[2px] mb-3">WHY WEBNOVA</div>
        <h2 class="text-4xl font-semibold tracking-tight">The best of both worlds</h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="card p-8">
          <div class="text-3xl mb-4">✦</div>
          <h3 class="font-semibold text-xl mb-3">Human Craft</h3>
          <p class="text-zinc-400">Every project is led by senior creatives who care deeply about quality and detail.</p>
        </div>
        <div class="card p-8">
          <div class="text-3xl mb-4">✦</div>
          <h3 class="font-semibold text-xl mb-3">AI Acceleration</h3>
          <p class="text-zinc-400">We use AI to move faster without compromising on quality or originality.</p>
        </div>
        <div class="card p-8">
          <div class="text-3xl mb-4">✦</div>
          <h3 class="font-semibold text-xl mb-3">European Standards</h3>
          <p class="text-zinc-400">Based in Berlin with a deep understanding of EU markets and culture.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center">
    <div class="max-w-xl mx-auto px-6">
      <h2 class="text-4xl font-semibold tracking-tight mb-6">Ready to build something exceptional?</h2>
      <a href={getLocalizedPath('/contact', lang)} class="btn btn-primary px-10 py-4 text-lg">Start a Conversation</a>
    </div>
  </section>
</Layout>
