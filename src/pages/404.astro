---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found">
  <div class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center">
      <div class="text-[120px] font-semibold tracking-[-6px] text-zinc-800">404</div>
      <h1 class="text-4xl font-semibold tracking-tight -mt-4 mb-3">Page not found</h1>
      <p class="text-xl text-zinc-400 mb-10 max-w-md mx-auto">The page you’re looking for doesn’t exist or has been moved.</p>
      
      <a href="/" class="btn btn-primary px-8 py-3">Return to homepage</a>
    </div>
  </div>
</Layout>
