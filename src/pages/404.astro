---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, getLocalizedPath } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const homeHref = getLocalizedPath('/', lang);
---

<Layout title="Page Not Found | WebNova">
  <div class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center">
      <div class="text-8xl font-bold tracking-tighter text-zinc-800 mb-4">404</div>
      <h1 class="text-4xl font-semibold tracking-tight mb-4">Page not found</h1>
      <p class="text-xl text-zinc-400 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href={homeHref} class="btn btn-primary px-8 py-3">Return to homepage</a>
    </div>
  </div>
</Layout>
