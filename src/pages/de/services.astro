---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { getAllServices } from '../../data/ai-services';
import { getLocalizedPath } from '../../i18n/translations';

const lang = 'de';
const services = getAllServices(lang);
---

<Layout 
  title="Unsere KI-Services | WebNova" 
  description="KI-gestützte kreative Services: Landingpages, Websites, Apps, Instagram Content, Avatare, Automatisierung und mehr."
>
  <div class="max-w-6xl mx-auto px-6 pt-16 pb-20">
    <div class="max-w-3xl mb-14">
      <div class="text-[#3b82f6] tracking-[2px] text-sm mb-3">KI-SERVICES</div>
      <h1 class="text-6xl font-semibold tracking-[-1.8px] mb-4">Unsere KI-gestützten Services</h1>
      <p class="text-2xl text-zinc-400">Von Design bis Automatisierung — menschliche Kreativität trifft KI-Power.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map(service => (
        <a href={getLocalizedPath(`/services/${service.slug}`, lang)} class="group card p-8 rounded-3xl flex flex-col hover:border-[#3b82f6] transition-all">
          <span class="material-symbols-outlined text-4xl mb-6 text-[#3b82f6]">{service.icon}</span>
          <div class="flex-1">
            <h3 class="text-2xl font-semibold tracking-tight mb-4 group-hover:text-[#3b82f6] transition-colors">{service.title}</h3>
            <p class="text-zinc-400 text-[15px] leading-relaxed mb-6">{service.heroSubtitle}</p>
          </div>
          <div class="pt-6 border-t border-zinc-800 text-sm font-medium flex justify-between items-center">
            <span class="text-[#3b82f6]">Mehr erfahren →</span>
            <span class="text-zinc-500">ab {service.pricing[0].price}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-16 text-center border-t border-zinc-800 pt-12">
      <p class="text-lg text-zinc-400 mb-6">Nicht sicher, welcher Service passt?</p>
      <Button href={getLocalizedPath('/contact', lang)} variant="primary" size="lg">
        Kostenlose Beratung
      </Button>
    </div>
  </div>
</Layout>
