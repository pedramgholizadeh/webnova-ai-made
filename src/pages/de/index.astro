---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { getAllServices } from '../../data/ai-services';

const lang = 'de';
const services = getAllServices(lang).slice(0, 6);
---

<Layout title="WebNova | Premium Creative AI Agency" description="Premium Creative Agency aus Berlin. KI-gestützte Design-, Web- und Automatisierungslösungen.">
  <section class="pt-24 pb-20 border-b border-zinc-800">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <div class="inline-block px-4 py-1 rounded-full border border-zinc-800 text-xs tracking-[2px] mb-6 text-[#3b82f6]">BERLIN • EU</div>
      
      <h1 class="text-7xl md:text-[72px] font-semibold tracking-[-3.5px] leading-[0.9] mb-6">
        Kreativität trifft KI.
      </h1>
      <p class="max-w-2xl mx-auto text-2xl text-zinc-400 mb-10">
        Eine Premium Creative Agency aus Berlin. Wir kombinieren menschliche Kreativität mit KI für außergewöhnliche digitale Erlebnisse.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="/de/services" class="btn btn-primary px-9 py-4 text-base">Services entdecken</a>
        <a href="/de/contact" class="btn btn-secondary px-9 py-4 text-base">Beratung buchen</a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <div class="text-[#3b82f6] text-sm tracking-[2px] mb-2">WAS WIR ANBIETEN</div>
        <h2 class="text-4xl font-semibold tracking-tight">KI-gestützte Services</h2>
      </div>
      <a href="/de/services" class="hidden md:block text-sm text-[#3b82f6]">Alle Services →</a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map(service => (
        <a href={`/de/services/${service.slug}`} class="group border border-zinc-800 p-8 rounded-3xl hover:border-[#3b82f6] transition-all">
          <span class="material-symbols-outlined text-3xl mb-6 text-[#3b82f6]">{service.icon}</span>
          <h3 class="font-semibold text-xl mb-3 group-hover:text-[#3b82f6]">{service.title}</h3>
          <p class="text-zinc-400 text-[15px] leading-relaxed line-clamp-3">{service.heroSubtitle}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-[#111113] py-20 border-y border-zinc-800">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <div class="text-[#3b82f6] text-sm tracking-[2px] mb-3">WARUM WEBNOVA</div>
        <h2 class="text-4xl font-semibold tracking-tight">Das Beste aus beiden Welten</h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="card p-8">
          <div class="text-3xl mb-4">✦</div>
          <h3 class="font-semibold text-xl mb-3">Menschliches Handwerk</h3>
          <p class="text-zinc-400">Jedes Projekt wird von erfahrenen Kreativen geleitet, die Wert auf Qualität legen.</p>
        </div>
        <div class="card p-8">
          <div class="text-3xl mb-4">✦</div>
          <h3 class="font-semibold text-xl mb-3">KI-Beschleunigung</h3>
          <p class="text-zinc-400">Wir nutzen KI, um schneller zu arbeiten – ohne Kompromisse bei Qualität.</p>
        </div>
        <div class="card p-8">
          <div class="text-3xl mb-4">✦</div>
          <h3 class="font-semibold text-xl mb-3">Europäische Standards</h3>
          <p class="text-zinc-400">Mit Sitz in Berlin und tiefem Verständnis für europäische Märkte.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 text-center">
    <div class="max-w-xl mx-auto px-6">
      <h2 class="text-4xl font-semibold tracking-tight mb-6">Bereit für etwas Außergewöhnliches?</h2>
      <a href="/de/contact" class="btn btn-primary px-10 py-4 text-lg">Gespräch starten</a>
    </div>
  </section>
</Layout>
