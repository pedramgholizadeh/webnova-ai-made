---
import Layout from '../../layouts/Layout.astro';

const team = [
  { name: "Anna Bergmann", role: "Creative Director & Gründerin", bio: "Ehemals bei Meta. Besessen von Klarheit, Handwerk und emotionaler Wirkung.", image: "https://picsum.photos/id/1005/400/400" },
  { name: "Maximilian Voss", role: "Head of Strategy", bio: "Über 10 Jahre Erfahrung. Zuvor bei Wolff Olins.", image: "https://picsum.photos/id/1011/400/400" },
  { name: "Sofia Laurent", role: "Design Director", bio: "Preisgekrönte Designerin mit Fokus auf Systemdenken.", image: "https://picsum.photos/id/1009/400/400" },
  { name: "Julian Keller", role: "Technical Director", bio: "Verbindet Design und Engineering. Früher bei einem großen Tech-Unternehmen.", image: "https://picsum.photos/id/201/400/400" },
  { name: "Lara Schmidt", role: "KI & Automation Lead", bio: "Spezialistin für KI-Implementierung und Geschäftsautomatisierung.", image: "https://picsum.photos/id/29/400/400" },
  { name: "David Moreau", role: "Client Director", bio: "Stellt sicher, dass jedes Projekt die Erwartungen übertrifft.", image: "https://picsum.photos/id/160/400/400" },
];
---

<Layout title="Unser Team | WebNova">
  <div class="max-w-6xl mx-auto px-6 pt-16 pb-24">
    <div class="max-w-2xl mb-12">
      <h1 class="text-6xl font-semibold tracking-[-2px] mb-4">Unser Team</h1>
      <p class="text-2xl text-zinc-400">Ein kleines Team von Spezialisten, die von Qualität und Ergebnissen besessen sind.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {team.map(member => (
        <div class="card p-8 rounded-3xl">
          <img src={member.image} alt={member.name} class="w-24 h-24 rounded-full object-cover mb-6" />
          <h3 class="text-2xl font-semibold">{member.name}</h3>
          <p class="text-[#3b82f6] mb-4">{member.role}</p>
          <p class="text-zinc-400">{member.bio}</p>
        </div>
      ))}
    </div>
  </div>
</Layout>
