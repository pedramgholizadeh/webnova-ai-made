---
import ServiceLanding from '../../components/ServiceLanding.astro';
import { getAllServices } from '../../data/ai-services';
import { getLangFromUrl } from '../../i18n/translations';

export async function getStaticPaths() {
  const services = getAllServices('en');
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service, lang: 'en' }
  }));
}

const { service, lang } = Astro.props;
---

<ServiceLanding service={service} lang={lang} />
