---
import { getLocalizedPath, type Lang, useTranslations } from '../i18n/translations';

interface Props {
  currentPath: string;
  lang: Lang;
}

const { currentPath, lang } = Astro.props;
const t = useTranslations(lang);

const navItems = [
  { href: '/', label: t('nav.home') },
  { href: '/about', label: t('nav.about') },
  { href: '/services', label: t('nav.services') },
  { href: '/work', label: t('nav.work') },
  { href: '/contact', label: t('nav.contact') },
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/' || currentPath === '/de';
  }
  const localized = getLocalizedPath(href, lang);
  return currentPath === localized || currentPath.startsWith(localized + '/');
};

const switchLang = lang === 'en' ? 'de' : 'en';
const switchLabel = lang === 'en' ? 'DE' : 'EN';
const switchHref = currentPath.replace(/^\/de/, '') || '/';
const targetPath = switchLang === 'de' 
  ? `/de${switchHref === '/' ? '' : switchHref}` 
  : switchHref;

const ctaText = t('nav.getInTouch');
---

<header class="sticky top-0 z-50 border-b border-zinc-800 bg-[#0a0a0b]/95 backdrop-blur-lg">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-20">
    <!-- Logo -->
    <a href={lang === 'de' ? '/de' : '/'} class="flex items-center gap-2 group">
      <div class="w-8 h-8 bg-[#3b82f6] rounded flex items-center justify-center">
        <span class="text-white font-bold text-xl tracking-tighter">W</span>
      </div>
      <span class="font-semibold text-2xl tracking-[-1.5px] text-white group-hover:text-[#3b82f6] transition-colors">WebNova</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-9 text-sm">
      {navItems.map(item => {
        const href = getLocalizedPath(item.href, lang);
        return (
          <a 
            href={href}
            class:list={[
              "nav-link text-sm font-medium transition-colors",
              { "active": isActive(item.href) }
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="hidden md:flex items-center gap-4">
      <!-- Language Switcher -->
      <a 
        href={targetPath}
        class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-zinc-400 hover:text-white border border-zinc-800 rounded-full hover:border-zinc-700 transition-colors"
        aria-label={lang === 'en' ? 'Switch to German' : 'Switch to English'}
      >
        <span>{switchLabel}</span>
      </a>

      <!-- CTA -->
      <a 
        href={getLocalizedPath('/contact', lang)} 
        class="btn btn-primary text-sm px-5 py-2.5"
      >
        {ctaText}
      </a>
    </div>

    <!-- Mobile -->
    <div class="md:hidden flex items-center gap-3">
      <a 
        href={targetPath}
        class="px-3 py-1 text-xs font-medium text-zinc-400 border border-zinc-800 rounded-full"
      >
        {switchLabel}
      </a>
      <button 
        id="mobile-menu-btn"
        aria-expanded="false"
        aria-label="Toggle menu"
        class="p-2 -mr-2 text-white"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-zinc-800 bg-[#0a0a0b]">
    <div class="px-6 py-8 flex flex-col gap-6 text-base">
      {navItems.map(item => {
        const href = getLocalizedPath(item.href, lang);
        return (
          <a href={href} class="font-medium text-lg py-1">
            {item.label}
          </a>
        );
      })}
      <div class="pt-4 border-t border-zinc-800">
        <a 
          href={getLocalizedPath('/contact', lang)} 
          class="btn btn-primary w-full justify-center"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </div>
</header>
