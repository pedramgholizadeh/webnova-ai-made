---
export interface Props {
  title: string;
  description: string;
  icon?: string;
  features?: string[];
}

const { title, description, icon = '★', features = [] } = Astro.props;
---

<div class="card group p-8 rounded-2xl h-full flex flex-col">
  <div class="w-11 h-11 rounded-xl bg-zinc-900 flex items-center justify-center mb-6 text-[#3b82f6] text-2xl group-hover:scale-110 transition-transform">
    {icon}
  </div>
  
  <h3 class="text-2xl font-semibold mb-3 tracking-tight">{title}</h3>
  <p class="text-zinc-400 text-[15px] leading-relaxed mb-6 flex-grow">
    {description}
  </p>
  
  {features.length > 0 && (
    <ul class="space-y-2 text-sm text-zinc-400">
      {features.map(feature => (
        <li class="flex items-start gap-2">
          <span class="text-[#3b82f6] mt-1">→</span>
          <span>{feature}</span>
        </li>
      ))}
    </ul>
  )}
</div>
