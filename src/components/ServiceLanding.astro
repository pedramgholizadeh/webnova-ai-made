---
import Layout from '../layouts/Layout.astro';
import { type ServiceData } from '../data/ai-services';
import { getLocalizedPath } from '../i18n/translations';

export interface Props {
  service: ServiceData;
  lang?: 'en' | 'de';
}

const { service, lang = 'en' } = Astro.props;
const isGerman = lang === 'de';

const ctaLabel = isGerman ? "Anfrage absenden" : "Submit Request";
const thankYou = isGerman 
  ? "Vielen Dank! Wir melden uns innerhalb von 24 Stunden bei Ihnen." 
  : "Thank you! We will get back to you within 24 hours.";
const formSubtitle = isGerman 
  ? "Füllen Sie das Formular aus und wir kontaktieren Sie innerhalb von 24 Stunden." 
  : "Fill out the form and we will get back to you within 24 hours.";
---

<Layout 
  title={`${service.title} | WebNova`}
  description={service.heroSubtitle}
>
  <!-- Hero -->
  <section class="relative pt-20 pb-16 border-b border-zinc-800">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-6xl mb-5">{service.icon}</div>
      <h1 class="text-5xl md:text-[56px] font-semibold tracking-[-2.2px] leading-none mb-6 max-w-5xl">
        {service.heroTitle}
      </h1>
      <p class="text-2xl text-zinc-400 max-w-3xl mb-10">
        {service.heroSubtitle}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#form" class="btn btn-primary px-8 py-3.5 text-base">Get Started</a>
        <a href="#pricing" class="btn btn-secondary px-8 py-3.5 text-base">View Pricing</a>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="max-w-5xl mx-auto px-6 py-16 border-b border-zinc-800">
    <div class="uppercase tracking-[2px] text-xs text-[#3b82f6] mb-3">THE CHALLENGE</div>
    <h2 class="text-4xl font-semibold tracking-tight mb-6">The Problem</h2>
    <p class="text-xl text-zinc-300 max-w-4xl leading-relaxed">{service.problem}</p>
  </section>

  <!-- Solution -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="uppercase tracking-[2px] text-xs text-[#3b82f6] mb-3">OUR APPROACH</div>
    <h2 class="text-4xl font-semibold tracking-tight mb-6">{service.solutionTitle}</h2>
    <p class="text-xl text-zinc-300 mb-10 leading-relaxed">{service.solutionDescription}</p>

    <div class="grid md:grid-cols-2 gap-4">
      {service.solutionPoints.map(point => (
        <div class="p-6 bg-[#111113] border border-zinc-800 rounded-2xl flex gap-4 items-start">
          <div class="text-[#3b82f6] mt-1">→</div>
          <p class="text-[15px] leading-relaxed">{point}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Samples -->
  <section class="bg-[#111113] py-16 border-y border-zinc-800">
    <div class="max-w-6xl mx-auto px-6">
      <div class="uppercase tracking-[2px] text-xs text-[#3b82f6] mb-3">SELECTED WORK</div>
      <h2 class="text-4xl font-semibold tracking-tight mb-10">Sample Projects</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {service.samples.map(sample => (
          <div class="group border border-zinc-800 rounded-2xl overflow-hidden bg-[#0a0a0b]">
            <img 
              src={sample.image} 
              alt={sample.title} 
              class="w-full aspect-video object-cover group-hover:scale-[1.02] transition-transform duration-500" 
            />
            <div class="p-6">
              <h4 class="font-semibold text-lg">{sample.title}</h4>
              <p class="text-sm text-zinc-400 mt-1">{sample.client}</p>
              <p class="text-[#3b82f6] text-sm mt-3 font-medium">{sample.result}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="max-w-6xl mx-auto px-6 py-20">
    <div class="text-center mb-12">
      <div class="uppercase tracking-[2px] text-xs text-[#3b82f6] mb-3">PRICING</div>
      <h2 class="text-4xl font-semibold tracking-tight">Transparent Pricing</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {service.pricing.map(tier => (
        <div class:list={[
          "border rounded-3xl p-8 flex flex-col",
          tier.popular ? "border-[#3b82f6] bg-[#111113] scale-[1.01]" : "border-zinc-800"
        ]}>
          <div>
            <div class="font-semibold text-2xl">{tier.name}</div>
            <div class="mt-3 text-4xl font-semibold tracking-tight">
              {tier.price} 
              <span class="text-base font-normal text-zinc-400">/{tier.period}</span>
            </div>
          </div>

          <ul class="mt-8 space-y-3.5 text-sm flex-1">
            {tier.features.map(f => (
              <li class="flex gap-3 text-zinc-300">✓ {f}</li>
            ))}
          </ul>

          <a href="#form" class="btn btn-primary mt-8 w-full justify-center">
            Choose {tier.name}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Lead Form -->
  <section id="form" class="bg-[#111113] py-16 border-t border-zinc-800">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-4xl font-semibold tracking-tight mb-3">{service.formTitle}</h2>
      <p class="text-zinc-400 mb-8 text-lg">{formSubtitle}</p>

      <form id="lead-form" class="space-y-6 bg-[#0a0a0b] p-8 rounded-3xl border border-zinc-800">
        <input type="hidden" name="service" value={service.slug} />
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <input type="text" name="name" placeholder={isGerman ? "Vollständiger Name" : "Full Name"} required class="w-full" />
          <input type="tel" name="phone" placeholder={isGerman ? "Telefonnummer" : "Phone Number"} class="w-full" />
        </div>
        
        <input type="email" name="email" placeholder={isGerman ? "E-Mail-Adresse" : "Email Address"} required class="w-full" />
        <input type="text" name="company" placeholder={isGerman ? "Unternehmen" : "Company"} class="w-full" />
        
        <select name="package" class="w-full">
          {service.pricing.map(t => (
            <option value={t.name}>{t.name} — {t.price}</option>
          ))}
        </select>

        <textarea 
          name="message" 
          rows="4" 
          placeholder={isGerman ? "Erzählen Sie uns von Ihrem Projekt..." : "Tell us about your project..."} 
          class="w-full"
        ></textarea>

        <button type="submit" class="btn btn-primary w-full py-3.5 text-base">{ctaLabel}</button>
      </form>

      <div id="form-success" class="hidden mt-6 p-6 bg-emerald-950/60 border border-emerald-800 rounded-2xl text-center text-emerald-400">
        {thankYou}
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const successDiv = document.getElementById('form-success');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      // Replace with your actual Cloudflare Worker URL
      const WORKER_URL = 'https://webnova-leads.webiro-ir.workers.dev/lead';

      try {
        const response = await fetch(WORKER_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          form.style.display = 'none';
          if (successDiv) successDiv.classList.remove('hidden');
        } else {
          throw new Error('Failed to submit');
        }
      } catch (err) {
        // Fallback simulation for development
        console.log('Form data (development):', data);
        form.style.display = 'none';
        if (successDiv) successDiv.classList.remove('hidden');
      }
    });
  }
</script>
