---
import { getLocalizedPath, type Lang, useTranslations } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const year = new Date().getFullYear();

const footerLinks = [
  { href: getLocalizedPath('/about', lang), label: t('nav.about') },
  { href: getLocalizedPath('/services', lang), label: t('nav.services') },
  { href: getLocalizedPath('/work', lang), label: t('nav.work') },
  { href: getLocalizedPath('/contact', lang), label: t('nav.contact') },
];
---

<footer class="border-t border-zinc-800 bg-[#0a0a0b]">
  <div class="max-w-7xl mx-auto px-6 pt-12 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-y-10 gap-x-8">
      <!-- Brand -->
      <div class="md:col-span-5">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 bg-[#3b82f6] rounded flex items-center justify-center">
            <span class="text-white font-bold text-lg tracking-tighter">W</span>
          </div>
          <span class="font-semibold text-xl tracking-[-1px]">WebNova</span>
        </div>
        <p class="text-sm text-zinc-400 max-w-xs">
          Premium creative agency.<br />
          Berlin, Germany — Europe.
        </p>
      </div>

      <!-- Links -->
      <div class="md:col-span-3">
        <div class="text-xs uppercase tracking-[1px] text-zinc-500 mb-4 font-medium">Navigate</div>
        <ul class="space-y-2 text-sm">
          {footerLinks.map(link => (
            <li><a href={link.href} class="text-zinc-400 hover:text-white">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div class="md:col-span-4 text-sm">
        <div class="text-xs uppercase tracking-[1px] text-zinc-500 mb-4 font-medium">Berlin</div>
        <div class="space-y-1 text-zinc-400">
          <div>Torstraße 1</div>
          <div>10119 Berlin, Germany</div>
          <div class="pt-1">
            <a href="mailto:hello@webnova.studio" class="hover:text-white">hello@webnova.studio</a>
          </div>
          <div>+49 30 123 4567</div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-zinc-800 flex flex-col md:flex-row md:items-center justify-between gap-y-3 text-xs text-zinc-500">
      <div>
        © {year} WebNova GmbH. {t('footer.rights')}
      </div>
      <div class="flex gap-x-6">
        <a href="#" class="hover:text-white">{t('footer.privacy')}</a>
        <a href="#" class="hover:text-white">{t('footer.imprint')}</a>
        <a href="#" class="hover:text-white">{t('footer.legal')}</a>
      </div>
    </div>
  </div>
</footer>
